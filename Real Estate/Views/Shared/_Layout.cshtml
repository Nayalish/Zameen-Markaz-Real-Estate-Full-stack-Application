					<li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Login">Signin</a></li>
					<li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Logout">Logout</a></li>
					@if (User.Identity != null && User.Identity.IsAuthenticated)
					{
						if (User.IsInRole("Admin"))
						{
							<li class="nav-item">
								<a class="nav-link text-dark" asp-controller="Home" asp-action="Admin">
									Admin Panel
								</a>
							</li>
						}
					}
				</ul>
				<p class="mb-0"><a href="#" class="btn btn-primary rounded">Submit A Property</a></p>
			</div>
		</div>
	</nav>
