@model IEnumerable<Real_Estate.Models.Agent>
@{
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

@{
    ViewData["Title"] = "Index";
}

<div class="centered-div mt-5">
			<div class="container-fluid">

					<div class="row">
						<div class="col-8 offset-2">
						<h1 class="text-center text-primary m-3"> Agent 👨‍🏫</h1>
						<a class="btn btn-sm btn-primary float-right p-1 m-1" asp-action="create" asp-controller="Agents" >Add Agent info 📝</a>
							<table class="table table-bordered table-hover">
								<thead>
									<tr class="text-center bg-dark text-light">
										<th>Name</th>
										
										<th>Location</th>
										<th>Image</th>
										<th>Action</th>
									</tr>
								</thead>
								<tbody class="text-center">
						@if (Model != null)
						{
							@foreach (var data in Model)
							{
													<tr>

														<td>@data.Name</td>
														
														<td>@data.Location</td>
														<td>
															<img src="~/images/@data.Path" height="150px;" width="150px;" />
														</td>

														<td>
															<a class="btn btn-sm btn-primary" asp-action="Edit"  asp-route-id="@data.Id">Edit</a>
															<a class="btn btn-sm btn-danger" onclick="return confirm('Aru You sure, You want to delete this image?');" asp-action="Delete"  asp-route-id="@data.Id">Delete</a>
															<a class="btn btn-sm btn-warning" asp-action="Details"  asp-route-id="@data.Id">Details</a>
														</td>
													</tr>
							}
						}
								</tbody>
							</table>

					</div>
				</div>
			</div>
		</div>
				

